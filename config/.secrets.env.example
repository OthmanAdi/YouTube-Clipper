# Copy this file to .secrets.env and fill in the values.
# .secrets.env is gitignored.

# ----- Azure Foundry (Azure OpenAI Service) -----
# Resource endpoint, e.g. https://YOUR-RESOURCE.openai.azure.com
AZURE_FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com

# Azure Foundry / Azure OpenAI API key.
AZURE_FOUNDRY_KEY=replace-me

# ----- Qwen (Alibaba Cloud MaaS — OpenAI-compatible mode) -----
# Endpoint format: https://<workspace>.<region>.maas.aliyuncs.com/compatible-mode/v1
# (No trailing slash; the adapter appends /chat/completions.)
QWEN_ENDPOINT=https://your-workspace.your-region.maas.aliyuncs.com/compatible-mode/v1

# Main API key (sk-... format from the Alibaba Cloud Model Studio console).
QWEN_API_KEY=replace-me

# Optional: workspace-specific keys if you provision per-user access tokens.
# Not currently consumed by the daemon — keep here for future multi-tenant routing.
# QWEN_API_KEY_USER_A=replace-me
# QWEN_API_KEY_USER_B=replace-me
